# Anseo — example environment for `docker compose --env-file=.env up`.
# Copy to `.env` (gitignored) before running locally if you want non-default values.
# Defaults are baked into compose.yml so an empty .env still works.

# Bind host for every published port. Defaults to 127.0.0.1 (localhost-only,
# matching Story 1.4 AC). Set to 0.0.0.0 only if you understand the privacy posture.
# ANSEO_BIND_HOST=127.0.0.1

# Host ports for each service (container ports are fixed).
# POSTGRES_PORT=5432
# REDIS_PORT=6379
# ANSEO_API_PORT=8080
# ANSEO_WEB_PORT=5173

# PostgreSQL credentials and database name. The api/worker containers build their
# DATABASE_URL from these.
# POSTGRES_USER=anseo
# POSTGRES_PASSWORD=anseo
# POSTGRES_DB=anseo

# Rust logging level for api + worker.
# RUST_LOG=info

# Override image tags to use published images instead of the local `:dev` builds.
# Defaults (when unset) are the locally-built anseo/{api,worker,web}:dev images.
# ANSEO_API_IMAGE=anseo/api:dev
# ANSEO_WORKER_IMAGE=anseo/worker:dev
# ANSEO_WEB_IMAGE=anseo/web:dev

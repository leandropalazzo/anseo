# Anseo — standalone production environment.
#
#   curl -fsSL https://anseo.ai/compose.yml     -o compose.yml
#   curl -fsSL https://anseo.ai/.env.example    -o .env
#   curl -fsSL https://anseo.ai/anseo.example.yaml -o anseo.example.yaml
#   # set ANSEO_VERSION + edit the CHANGE THIS values below, then:
#   docker compose up -d
#
# This file ships with NO default image version: you MUST set ANSEO_VERSION to a
# published release tag before the stack will start (the compose file refuses to
# boot otherwise). Everything else defaults to a localhost-only trial (every
# port binds 127.0.0.1). Before exposing the stack to a network, rotate EVERY
# value marked "CHANGE THIS before exposing".

# ─── Image version (REQUIRED — no default) ──────────────────────────────────
# Pinned release tag for the published GHCR images (api + worker + web). MUST be
# a real PUBLISHED tag in X.Y.Z form — never `latest`/`dev`, so deploys are
# reproducible and rollbacks are clean. Find released tags at
# https://github.com/leandropalazzo/anseo/releases (or `docker pull
# ghcr.io/leandropalazzo/anseo/api:<tag>` to confirm it exists). There is no
# default on purpose: an unset/empty value makes the stack fail fast with a
# clear error rather than pulling a nonexistent or incompatible image.
ANSEO_VERSION=

# Registry + repo prefix for the published images. Resolves to
# <ANSEO_IMAGE_REGISTRY>/{api,worker,web}:<ANSEO_VERSION>. Parameterized so a
# future registry/repo rename is a one-line change here.
ANSEO_IMAGE_REGISTRY=ghcr.io/leandropalazzo/anseo

# ─── Project config ─────────────────────────────────────────────────────────
# Host path to the canonical Anseo YAML mounted read-only into api + worker at
# /anseo.yaml. Edit the shipped example in place for a trial, or copy it to
# anseo.yaml and set ANSEO_PROJECT_CONFIG=./anseo.yaml for your deployment.
# Keep provider API keys out of this file.
ANSEO_PROJECT_CONFIG=./anseo.example.yaml
# ANSEO_CONFIG=/anseo.yaml

# ─── Network exposure ───────────────────────────────────────────────────────
# Bind host for every published port. Defaults to 127.0.0.1 (localhost-only).
# Set to 0.0.0.0 ONLY behind a reverse proxy/TLS you control — see
# https://anseo.ai/docs/deploy for the exposure baseline.
# ANSEO_BIND_HOST=127.0.0.1

# Host ports for each service (container ports are fixed).
# POSTGRES_PORT=5432
# REDIS_PORT=6379
# ANSEO_API_PORT=8080
# ANSEO_WEB_PORT=5173

# ─── Secrets — CHANGE THIS before exposing ──────────────────────────────────
# Bootstrap API key seeded on first boot. The dashboard/SSR + healthchecks use
# it. Must match the wire shape `ogeo_<32 base62>`.
# CHANGE THIS before exposing — the default is a well-known DEV credential.
# IMPORTANT: this key is persisted into Postgres on the FIRST boot (it is seeded
# only when the project has zero active keys). If you ran the trial with the
# default and then change this value, the old well-known key STAYS VALID in the
# database — editing .env does not revoke it. Either set a strong key here BEFORE
# the first `up`, or, if you already trialed, revoke the seeded key in the DB
# before exposing (see https://anseo.ai/docs/deploy → exposure baseline).
ANSEO_BOOTSTRAP_API_KEY=ogeo_DevComposeBootstrapKeyDoNotUse01

# Passphrase that unlocks the age-encrypted provider-secrets file (where keys
# set via the dashboard persist). CHANGE THIS before exposing — a known
# passphrase makes those provider keys recoverable from the volume.
ANSEO_KEYRING_PASSPHRASE=dev-compose-secrets-passphrase

# ─── PostgreSQL ─────────────────────────────────────────────────────────────
# The api/worker build their DATABASE_URL from these. CHANGE THIS before
# exposing — leaving the default password is unsafe on any reachable host.
# NOTE: POSTGRES_PASSWORD is interpolated into a postgres:// URI. Keep it
# URL-safe (letters/digits/-._~). If you need a password with URI-reserved
# characters (@ : / # % ? & = + space), set DATABASE_URL below directly with the
# password percent-encoded — it overrides the generated URL for api + worker.
POSTGRES_USER=anseo
POSTGRES_PASSWORD=anseo   # CHANGE THIS before exposing
POSTGRES_DB=anseo
# DATABASE_URL=postgres://anseo:percent%40encoded@postgres:5432/anseo

# ─── Logging ────────────────────────────────────────────────────────────────
# RUST_LOG=info

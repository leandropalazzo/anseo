# Anseo — standalone production environment.
#
#   curl -fsSL https://anseo.ai/compose.yml     -o compose.yml
#   curl -fsSL https://anseo.ai/.env.example    -o .env
#   curl -fsSL https://anseo.ai/anseo.example.yaml -o anseo.example.yaml
#   # edit the CHANGE THIS values below, then:
#   docker compose up -d
#
# Copied UNEDITED, this file still boots a localhost trial (everything binds
# 127.0.0.1). Before exposing the stack to a network, rotate EVERY value marked
# "CHANGE THIS before exposing".

# ─── Image version (REQUIRED) ───────────────────────────────────────────────
# Pinned release tag for the published GHCR images. MUST be a vX.Y.Z — never
# `latest` or `dev`, so deploys are reproducible and rollbacks are clean.
ANSEO_VERSION=v0.5.0

# Registry + repo prefix for the published images. Resolves to
# <ANSEO_IMAGE_REGISTRY>/{api,worker,web}:<ANSEO_VERSION>. Parameterized so a
# future registry/repo rename is a one-line change here.
ANSEO_IMAGE_REGISTRY=ghcr.io/leandropalazzo/opengeo

# ─── Project config ─────────────────────────────────────────────────────────
# Host path to the canonical Anseo YAML mounted read-only into api + worker at
# /anseo.yaml. Edit the shipped example in place for a trial, or copy it to
# anseo.yaml and set ANSEO_PROJECT_CONFIG=./anseo.yaml for your deployment.
# Keep provider API keys out of this file.
ANSEO_PROJECT_CONFIG=./anseo.example.yaml
# ANSEO_CONFIG=/anseo.yaml

# ─── Network exposure ───────────────────────────────────────────────────────
# Bind host for every published port. Defaults to 127.0.0.1 (localhost-only).
# Set to 0.0.0.0 ONLY behind a reverse proxy/TLS you control — see
# https://anseo.ai/docs/deploy for the exposure baseline.
# ANSEO_BIND_HOST=127.0.0.1

# Host ports for each service (container ports are fixed).
# POSTGRES_PORT=5432
# REDIS_PORT=6379
# ANSEO_API_PORT=8080
# ANSEO_WEB_PORT=5173

# ─── Secrets — CHANGE THIS before exposing ──────────────────────────────────
# Bootstrap API key seeded on first boot. The dashboard/SSR + healthchecks use
# it. Must match the wire shape `ogeo_<32 base62>`.
# CHANGE THIS before exposing — the default is a well-known DEV credential.
ANSEO_BOOTSTRAP_API_KEY=ogeo_DevComposeBootstrapKeyDoNotUse01

# Passphrase that unlocks the age-encrypted provider-secrets file (where keys
# set via the dashboard persist). CHANGE THIS before exposing — a known
# passphrase makes those provider keys recoverable from the volume.
ANSEO_KEYRING_PASSPHRASE=dev-compose-secrets-passphrase

# ─── PostgreSQL ─────────────────────────────────────────────────────────────
# The api/worker build their DATABASE_URL from these. CHANGE THIS before
# exposing — leaving the default password is unsafe on any reachable host.
POSTGRES_USER=anseo
POSTGRES_PASSWORD=anseo   # CHANGE THIS before exposing
POSTGRES_DB=anseo

# ─── Logging ────────────────────────────────────────────────────────────────
# RUST_LOG=info

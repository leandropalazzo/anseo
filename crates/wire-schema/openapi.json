{
  "components": {
    "parameters": {
      "ProjectHeader": {
        "description": "Story 0.11 substrate (Phase 3 decision L2). Identifies the target project. Phase 2 single-project deployments accept the header for forward-compatibility: the value must equal the configured project name (case-insensitive after trim) or the reserved sentinel `default`. Mismatching values return 403 `project_not_found`. Absent header is accepted in Phase 2 (with a one-time per-process WARN log) and will become required in Phase 4 multi-project mode.",
        "in": "header",
        "name": "X-OpenGEO-Project",
        "required": false,
        "schema": {
          "type": "string"
        }
      }
    },
    "responses": {
      "Unauthorized": {
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/Error"
            }
          }
        },
        "description": "Missing, malformed, or revoked X-OpenGEO-API-Key. The body shape is intentionally opaque so an unauthenticated caller cannot distinguish 'wrong key' from 'auth backend down'."
      }
    },
    "schemas": {
      "AnomaliesResponse": {
        "properties": {
          "items": {
            "items": {
              "$ref": "#/components/schemas/AnomalyItem"
            },
            "type": "array"
          },
          "trace_id": {
            "type": "string"
          }
        },
        "required": [
          "items",
          "trace_id"
        ],
        "type": "object"
      },
      "AnomalyItem": {
        "properties": {
          "id": {
            "description": "ULID-form anomaly emission id.",
            "format": "ulid",
            "type": "string"
          },
          "kind": {
            "enum": [
              "visibility_drop",
              "citation_loss",
              "rank_swap"
            ],
            "type": "string"
          },
          "prompt": {
            "nullable": true,
            "type": "string"
          },
          "provider": {
            "description": "Wire-stable provider identifier (`openai|anthropic|gemini|perplexity|…`).",
            "type": "string"
          },
          "detected_at": {
            "format": "date-time",
            "type": "string"
          },
          "severity": {
            "enum": [
              "low",
              "medium",
              "high"
            ],
            "type": "string"
          },
          "delta": {
            "description": "Opaque effect-size signal; consumers MUST NOT compare across kinds.",
            "type": "number"
          },
          "window_days": {
            "minimum": 1,
            "type": "integer"
          },
          "details": {
            "description": "Verbatim detector detail blob. Shape varies by `kind`.",
            "type": "object"
          }
        },
        "required": [
          "id",
          "kind",
          "provider",
          "detected_at",
          "severity",
          "delta",
          "window_days",
          "details"
        ],
        "type": "object"
      },
      "BrandEntry": {
        "properties": {
          "name": {
            "type": "string"
          },
          "is_primary": {
            "type": "boolean"
          },
          "mention_count_7d": {
            "format": "int64",
            "type": "integer"
          },
          "avg_rank_7d": {
            "nullable": true,
            "type": "number"
          },
          "providers_with_data": {
            "items": {
              "type": "string"
            },
            "type": "array"
          }
        },
        "required": [
          "name",
          "is_primary",
          "mention_count_7d",
          "providers_with_data"
        ],
        "type": "object"
      },
      "BrandsResponse": {
        "properties": {
          "items": {
            "items": {
              "$ref": "#/components/schemas/BrandEntry"
            },
            "type": "array"
          }
        },
        "required": [
          "items"
        ],
        "type": "object"
      },
      "CitationDomainEntry": {
        "properties": {
          "domain": {
            "type": "string"
          },
          "frequency": {
            "format": "int64",
            "type": "integer"
          },
          "source_type": {
            "nullable": true,
            "type": "string"
          },
          "sample_prompt_run_ids": {
            "description": "At most 5 sample prompt-run ULIDs (architecture-phase3-mcp-server.md §3.4).",
            "items": {
              "type": "string"
            },
            "maxItems": 5,
            "type": "array"
          }
        },
        "required": [
          "domain",
          "frequency",
          "sample_prompt_run_ids"
        ],
        "type": "object"
      },
      "CitationProviderBreakdownEntry": {
        "properties": {
          "provider": {
            "type": "string"
          },
          "frequency": {
            "format": "int64",
            "type": "integer"
          }
        },
        "required": [
          "provider",
          "frequency"
        ],
        "type": "object"
      },
      "CitationSummaryResponse": {
        "description": "Story 0.9 extension: `domains` retained for backward compatibility; new fields are additive.",
        "properties": {
          "domains": {
            "items": {
              "$ref": "#/components/schemas/CitationDomainEntry"
            },
            "type": "array"
          },
          "provider_breakdown": {
            "items": {
              "$ref": "#/components/schemas/CitationProviderBreakdownEntry"
            },
            "type": "array"
          },
          "top_domains": {
            "items": {
              "$ref": "#/components/schemas/CitationDomainEntry"
            },
            "type": "array"
          },
          "growth_rate": {
            "description": "Ratio of current-window total over prior-equal-window total minus 1. `null` when the prior window had zero citations.",
            "nullable": true,
            "type": "number"
          },
          "window_days": {
            "minimum": 1,
            "type": "integer"
          }
        },
        "required": [
          "domains",
          "provider_breakdown",
          "top_domains",
          "window_days"
        ],
        "type": "object"
      },
      "ComparisonCell": {
        "properties": {
          "mention_count": {
            "minimum": 0,
            "type": "integer"
          },
          "ranking": {
            "minimum": 1,
            "nullable": true,
            "type": "integer"
          },
          "subject": {
            "type": "string"
          }
        },
        "required": [
          "subject",
          "mention_count"
        ],
        "type": "object"
      },
      "ComparisonRow": {
        "properties": {
          "cells": {
            "items": {
              "$ref": "#/components/schemas/ComparisonCell"
            },
            "type": "array"
          },
          "prompt_id": {
            "description": "ULID.",
            "type": "string"
          },
          "prompt_name": {
            "type": "string"
          },
          "provider": {
            "type": "string"
          }
        },
        "required": [
          "prompt_id",
          "prompt_name",
          "provider",
          "cells"
        ],
        "type": "object"
      },
      "ComparisonsResponse": {
        "description": "Story 0.8 `GET /v1/comparisons` matrix payload — mirrors the MCP CompareBrandsOutput shape (architecture-phase3-mcp-server.md §3.3). Determinism contract: rows ordered (prompt_name ASC, provider ASC); cells ordered [brand, ...competitors_in_caller_order]; absent subjects carry ranking:null (NOT omitted).",
        "properties": {
          "brand": {
            "type": "string"
          },
          "competitors": {
            "items": {
              "type": "string"
            },
            "type": "array"
          },
          "rows": {
            "items": {
              "$ref": "#/components/schemas/ComparisonRow"
            },
            "type": "array"
          },
          "trace_id": {
            "type": "string"
          },
          "window": {
            "enum": [
              "7d",
              "30d",
              "all"
            ],
            "type": "string"
          }
        },
        "required": [
          "window",
          "brand",
          "competitors",
          "rows",
          "trace_id"
        ],
        "type": "object"
      },
      "PromptRunSummaryItem": {
        "properties": {
          "prompt": {
            "type": "string"
          },
          "run_count": {
            "format": "int64",
            "type": "integer"
          },
          "last_run_at": {
            "format": "date-time",
            "nullable": true,
            "type": "string"
          },
          "success_rate": {
            "description": "Fraction in [0, 1]; `null` when `run_count == 0`.",
            "nullable": true,
            "type": "number"
          },
          "avg_latency_ms": {
            "nullable": true,
            "type": "number"
          },
          "providers": {
            "items": {
              "type": "string"
            },
            "type": "array"
          }
        },
        "required": [
          "prompt",
          "run_count",
          "providers"
        ],
        "type": "object"
      },
      "PromptRunSummaryResponse": {
        "properties": {
          "items": {
            "items": {
              "$ref": "#/components/schemas/PromptRunSummaryItem"
            },
            "type": "array"
          },
          "since": {
            "format": "date-time",
            "type": "string"
          }
        },
        "required": [
          "items",
          "since"
        ],
        "type": "object"
      },
      "CreatePromptRunRequest": {
        "properties": {
          "prompt_name": {
            "description": "Slug-safe prompt identifier declared in opengeo.yaml.",
            "type": "string"
          },
          "provider": {
            "enum": [
              "openai",
              "anthropic",
              "gemini",
              "perplexity",
              "grok",
              "mistral",
              "openrouter",
              "mock"
            ],
            "type": "string"
          },
          "triggered_by": {
            "nullable": true,
            "type": "string"
          }
        },
        "required": [
          "prompt_name",
          "provider"
        ],
        "type": "object"
      },
      "CreatePromptRunResponse": {
        "properties": {
          "dispatched_at": {
            "format": "date-time",
            "type": "string"
          },
          "project_id": {
            "type": "string"
          },
          "prompt_name": {
            "type": "string"
          },
          "provider": {
            "type": "string"
          },
          "run_id": {
            "type": "string"
          },
          "status": {
            "type": "string"
          }
        },
        "required": [
          "status",
          "run_id",
          "project_id",
          "prompt_name",
          "provider",
          "dispatched_at"
        ],
        "type": "object"
      },
      "Error": {
        "properties": {
          "error": {
            "type": "string"
          },
          "message": {
            "type": "string"
          }
        },
        "required": [
          "error",
          "message"
        ],
        "type": "object"
      },
      "RunListResponse": {
        "properties": {
          "runs": {
            "items": {
              "type": "object"
            },
            "type": "array"
          }
        },
        "type": "object"
      },
      "VisibilityTrendResponse": {
        "properties": {
          "points": {
            "items": {
              "type": "object"
            },
            "type": "array"
          }
        },
        "type": "object"
      },
      "SimilarityIndexResponse": {
        "properties": {
          "input_hash": {
            "description": "SHA-256 of the input text, hex-encoded with `sha256:` prefix.",
            "type": "string"
          },
          "matches": {
            "items": {
              "$ref": "#/components/schemas/SimilarityMatch"
            },
            "type": "array"
          },
          "method": {
            "enum": ["minhash"],
            "type": "string"
          },
          "num_hash_functions": {
            "type": "integer"
          }
        },
        "required": ["input_hash", "matches", "method", "num_hash_functions"],
        "type": "object"
      },
      "SimilarityMatch": {
        "properties": {
          "name": {
            "type": "string"
          },
          "prompt": {
            "type": "string"
          },
          "estimated_jaccard": {
            "maximum": 1.0,
            "minimum": 0.0,
            "type": "number"
          },
          "configured_at": {
            "description": "Reserved — null in Phase 3.",
            "nullable": true,
            "type": "string"
          },
          "rank_data_available": {
            "type": "boolean"
          }
        },
        "required": ["name", "prompt", "estimated_jaccard", "rank_data_available"],
        "type": "object"
      }
    },
    "securitySchemes": {
      "ApiKeyAuth": {
        "in": "header",
        "name": "X-OpenGEO-API-Key",
        "type": "apiKey"
      }
    }
  },
  "info": {
    "description": "Phase 2 v1 surface — read endpoints, prompt run submission, and the SSE event stream. Auth: X-OpenGEO-API-Key header carrying an `ogeo_<32 chars>` key. Story 0.11 (Phase 3 substrate) adds the optional X-OpenGEO-Project header — Phase 2 accepts it for forward compatibility; Phase 4 will require it.",
    "title": "OpenGEO Public REST API",
    "version": "0.3.0"
  },
  "openapi": "3.0.3",
  "paths": {
    "/v1/anomalies": {
      "get": {
        "operationId": "listAnomalies",
        "parameters": [
          {
            "$ref": "#/components/parameters/ProjectHeader"
          },
          {
            "description": "Optional prompt-slug equality filter.",
            "in": "query",
            "name": "prompt",
            "schema": {
              "type": "string"
            }
          },
          {
            "description": "Optional wire-stable provider equality filter.",
            "in": "query",
            "name": "provider",
            "schema": {
              "type": "string"
            }
          },
          {
            "description": "Trailing time window. Default `7d`.",
            "in": "query",
            "name": "window",
            "schema": {
              "default": "7d",
              "enum": [
                "1d",
                "7d",
                "30d"
              ],
              "type": "string"
            }
          },
          {
            "description": "Detector kind filter. Default `all`.",
            "in": "query",
            "name": "kind",
            "schema": {
              "default": "all",
              "enum": [
                "visibility",
                "citation",
                "all"
              ],
              "type": "string"
            }
          },
          {
            "description": "RFC 3339 lower bound on `detected_at`. AND-ed with `window`.",
            "in": "query",
            "name": "since",
            "schema": {
              "format": "date-time",
              "type": "string"
            }
          },
          {
            "$ref": "#/components/parameters/ProjectHeader"
          }
        ],
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AnomaliesResponse"
                }
              }
            },
            "description": "OK"
          },
          "400": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            },
            "description": "Invalid query parameter (unknown enum variant, malformed `since`)."
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          }
        },
        "summary": "List detector-emitted anomalies for the authenticated project."
      }
    },
    "/v1/brands": {
      "get": {
        "operationId": "listBrands",
        "parameters": [
          {
            "$ref": "#/components/parameters/ProjectHeader"
          }
        ],
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/BrandsResponse"
                }
              }
            },
            "description": "OK"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          },
          "503": {
            "description": "API booted without a readable `opengeo.yaml`; brand list cannot be resolved."
          }
        },
        "summary": "List configured brands plus 7-day mention stats (Story 0.9)."
      }
    },
    "/v1/citations/summary": {
      "get": {
        "operationId": "citationSummary",
        "parameters": [
          {
            "$ref": "#/components/parameters/ProjectHeader"
          },
          {
            "in": "query",
            "name": "limit",
            "schema": {
              "maximum": 500,
              "minimum": 1,
              "type": "integer"
            }
          },
          {
            "description": "Window in days. Default 30, range [1, 365].",
            "in": "query",
            "name": "days",
            "schema": {
              "maximum": 365,
              "minimum": 1,
              "type": "integer"
            }
          },
          {
            "description": "Filter to a single provider wire name.",
            "in": "query",
            "name": "provider",
            "schema": {
              "type": "string"
            }
          },
          {
            "description": "Filter to a single prompt name (slug-safe).",
            "in": "query",
            "name": "prompt",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CitationSummaryResponse"
                }
              }
            },
            "description": "OK"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          }
        },
        "summary": "Citation domains rollup. Story 0.9 adds `sample_prompt_run_ids` per item plus `provider_breakdown`, `top_domains`, `growth_rate`, `window_days`."
      }
    },
    "/v1/prompts/run-summary": {
      "get": {
        "operationId": "promptsRunSummary",
        "parameters": [
          {
            "$ref": "#/components/parameters/ProjectHeader"
          },
          {
            "description": "RFC3339 lower bound. Defaults to now()-30d.",
            "in": "query",
            "name": "since",
            "schema": {
              "format": "date-time",
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PromptRunSummaryResponse"
                }
              }
            },
            "description": "OK"
          },
          "400": {
            "description": "`since` was not a parseable RFC3339 timestamp."
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          }
        },
        "summary": "Per-prompt run state aggregation since `since` (Story 0.9)."
      }
    },
    "/v1/comparisons": {
      "get": {
        "operationId": "comparisons",
        "parameters": [
          {
            "$ref": "#/components/parameters/ProjectHeader"
          },
          {
            "description": "Comma-separated; 2..=6 entries. First entry is the subject brand; remainder are competitors in caller-declared order.",
            "in": "query",
            "name": "brands",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "description": "Comma-separated prompt names; default = all prompts for the project.",
            "in": "query",
            "name": "prompts",
            "schema": {
              "type": "string"
            }
          },
          {
            "description": "Comma-separated provider names; default = all providers.",
            "in": "query",
            "name": "providers",
            "schema": {
              "type": "string"
            }
          },
          {
            "in": "query",
            "name": "window",
            "schema": {
              "default": "7d",
              "enum": [
                "1d",
                "7d",
                "30d"
              ],
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ComparisonsResponse"
                }
              }
            },
            "description": "OK"
          },
          "400": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            },
            "description": "Validation error (e.g. `brands` outside 2..=6, or unknown `window`)."
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          }
        },
        "summary": "Phase 3 Story 0.8 — deterministic brand-vs-competitors comparison matrix (substrate for MCP `compare_brands`)."
      }
    },
    "/v1/healthz": {
      "get": {
        "operationId": "healthz",
        "parameters": [
          {
            "$ref": "#/components/parameters/ProjectHeader"
          }
        ],
        "responses": {
          "200": {
            "content": {
              "text/plain": {
                "schema": {
                  "example": "ok",
                  "type": "string"
                }
              }
            },
            "description": "OK"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          }
        },
        "summary": "Health probe"
      }
    },
    "/v1/projects/{project_id}/events": {
      "get": {
        "operationId": "subscribeEvents",
        "parameters": [
          {
            "$ref": "#/components/parameters/ProjectHeader"
          },
          {
            "in": "path",
            "name": "project_id",
            "required": true,
            "schema": {
              "format": "uuid",
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "content": {
              "text/event-stream": {}
            },
            "description": "text/event-stream subscription"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          },
          "403": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            },
            "description": "Cross-project subscription attempt; key authorized for a different project_id."
          }
        },
        "summary": "Server-Sent Events stream of ARCH-17 lifecycle events for one project."
      }
    },
    "/v1/prompt-runs": {
      "post": {
        "operationId": "createPromptRun",
        "parameters": [
          {
            "$ref": "#/components/parameters/ProjectHeader"
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreatePromptRunRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "202": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CreatePromptRunResponse"
                }
              }
            },
            "description": "Accepted"
          },
          "400": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            },
            "description": "Validation error"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          }
        },
        "summary": "Dispatch a one-shot prompt run for an already-declared Prompt and Provider."
      }
    },
    "/v1/prompts/similarity-index": {
      "get": {
        "operationId": "promptsSimilarityIndex",
        "parameters": [
          {
            "description": "Input prompt text to find configured-prompt matches for. Max 4096 chars.",
            "in": "query",
            "name": "text",
            "required": true,
            "schema": {
              "maxLength": 4096,
              "type": "string"
            }
          },
          {
            "description": "Minimum MinHash-estimated Jaccard similarity to return. Default 0.6.",
            "in": "query",
            "name": "threshold",
            "schema": {
              "default": 0.6,
              "maximum": 1.0,
              "minimum": 0.0,
              "type": "number"
            }
          },
          {
            "description": "Maximum number of matches to return. Default 10, max 50.",
            "in": "query",
            "name": "limit",
            "schema": {
              "default": 10,
              "maximum": 50,
              "minimum": 1,
              "type": "integer"
            }
          },
          {
            "$ref": "#/components/parameters/ProjectHeader"
          }
        ],
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SimilarityIndexResponse"
                }
              }
            },
            "description": "OK"
          },
          "400": {
            "content": {
              "application/json": {

{
  "components": {
    "parameters": {
      "ProjectHeader": {
        "description": "Story 0.11 substrate (Phase 3 decision L2). Identifies the target project. Phase 2 single-project deployments accept the header for forward-compatibility: the value must equal the configured project name (case-insensitive after trim) or the reserved sentinel `default`. Mismatching values return 403 `project_not_found`. Absent header is accepted in Phase 2 (with a one-time per-process WARN log) and will become required in Phase 4 multi-project mode.",
        "in": "header",
        "name": "X-OpenGEO-Project",
        "required": false,
        "schema": {
          "type": "string"
        }
      }
    },
    "responses": {
      "Unauthorized": {
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/Error"
            }
          }
        },
        "description": "Missing, malformed, or revoked X-OpenGEO-API-Key. The body shape is intentionally opaque so an unauthenticated caller cannot distinguish 'wrong key' from 'auth backend down'."
      }
    },
    "schemas": {
      "CitationSummaryResponse": {
        "properties": {
          "domains": {
            "items": {
              "type": "object"
            },
            "type": "array"
          }
        },
        "type": "object"
      },
      "ClickHouseInstallAccepted": {
        "description": "Story 15.1 — 202 response from POST /v1/setup/clickhouse/install. `install_id` is a ULID the caller can use to subscribe to the SSE progress stream. MOCK in 15.1; real Docker calls land in Story 15.3.",
        "properties": {
          "install_id": {
            "description": "ULID identifying the install.",
            "type": "string"
          },
          "stream": {
            "description": "Path to the SSE progress stream.",
            "type": "string"
          }
        },
        "required": [
          "install_id",
          "stream"
        ],
        "type": "object"
      },
      "ClickHouseInstallEvent": {
        "description": "Story 15.1 — one frame of the SSE install stream. Step ordering: docker_detected → image_pulling → container_starting → provisioning_user → applying_migrations → running_parity_test → complete.",
        "properties": {
          "at": {
            "format": "date-time",
            "type": "string"
          },
          "log_line": {
            "type": "string"
          },
          "progress": {
            "maximum": 1.0,
            "minimum": 0.0,
            "type": "number"
          },
          "step": {
            "enum": [
              "docker_detected",
              "image_pulling",
              "container_starting",
              "provisioning_user",
              "applying_migrations",
              "running_parity_test",
              "complete"
            ],
            "type": "string"
          }
        },
        "required": [
          "step",
          "progress",
          "log_line",
          "at"
        ],
        "type": "object"
      },
      "ComparisonCell": {
        "properties": {
          "mention_count": {
            "minimum": 0,
            "type": "integer"
          },
          "ranking": {
            "minimum": 1,
            "nullable": true,
            "type": "integer"
          },
          "subject": {
            "type": "string"
          }
        },
        "required": [
          "subject",
          "mention_count"
        ],
        "type": "object"
      },
      "ComparisonRow": {
        "properties": {
          "cells": {
            "items": {
              "$ref": "#/components/schemas/ComparisonCell"
            },
            "type": "array"
          },
          "prompt_id": {
            "description": "ULID.",
            "type": "string"
          },
          "prompt_name": {
            "type": "string"
          },
          "provider": {
            "type": "string"
          }
        },
        "required": [
          "prompt_id",
          "prompt_name",
          "provider",
          "cells"
        ],
        "type": "object"
      },
      "ComparisonsResponse": {
        "description": "Story 0.8 `GET /v1/comparisons` matrix payload — mirrors the MCP CompareBrandsOutput shape (architecture-phase3-mcp-server.md §3.3). Determinism contract: rows ordered (prompt_name ASC, provider ASC); cells ordered [brand, ...competitors_in_caller_order]; absent subjects carry ranking:null (NOT omitted).",
        "properties": {
          "brand": {
            "type": "string"
          },
          "competitors": {
            "items": {
              "type": "string"
            },
            "type": "array"
          },
          "rows": {
            "items": {
              "$ref": "#/components/schemas/ComparisonRow"
            },
            "type": "array"
          },
          "trace_id": {
            "type": "string"
          },
          "window": {
            "enum": [
              "7d",
              "30d",
              "all"
            ],
            "type": "string"
          }
        },
        "required": [
          "window",
          "brand",
          "competitors",
          "rows",
          "trace_id"
        ],
        "type": "object"
      },
      "CreatePromptRunRequest": {
        "properties": {
          "prompt_name": {
            "description": "Slug-safe prompt identifier declared in opengeo.yaml.",
            "type": "string"
          },
          "provider": {
            "enum": [
              "openai",
              "anthropic",
              "gemini",
              "perplexity",
              "grok",
              "mistral",
              "openrouter",
              "mock"
            ],
            "type": "string"
          },
          "triggered_by": {
            "nullable": true,
            "type": "string"
          }
        },
        "required": [
          "prompt_name",
          "provider"
        ],
        "type": "object"
      },
      "CreatePromptRunResponse": {
        "properties": {
          "dispatched_at": {
            "format": "date-time",
            "type": "string"
          },
          "project_id": {
            "type": "string"
          },
          "prompt_name": {
            "type": "string"
          },
          "provider": {
            "type": "string"
          },
          "run_id": {
            "type": "string"
          },
          "status": {
            "type": "string"
          }
        },
        "required": [
          "status",
          "run_id",
          "project_id",
          "prompt_name",
          "provider",
          "dispatched_at"
        ],
        "type": "object"
      },
      "Error": {
        "properties": {
          "error": {
            "type": "string"
          },
          "message": {
            "type": "string"
          }
        },
        "required": [
          "error",
          "message"
        ],
        "type": "object"
      },
      "RunListResponse": {
        "properties": {
          "runs": {
            "items": {
              "type": "object"
            },
            "type": "array"
          }
        },
        "type": "object"
      },
      "SetupStatus": {
        "description": "Story 15.1 — best-effort status probe across all deployment surfaces. Always returned 200; individual sections carry `state: \"unknown\"` + an `error` string on failure (per-probe timeout: 1s; 500ms for Docker).",
        "properties": {
          "api_keys": {
            "items": {
              "properties": {
                "configured": {
                  "type": "boolean"
                },
                "last_used_at": {
                  "format": "date-time",
                  "nullable": true,
                  "type": "string"
                },
                "provider": {
                  "type": "string"
                }
              },
              "required": [
                "provider",
                "configured"
              ],
              "type": "object"
            },
            "type": "array"
          },
          "clickhouse": {
            "properties": {
              "error": {
                "type": "string"
              },
              "etl_lag_seconds": {
                "nullable": true,
                "type": "number"
              },
              "row_count": {
                "nullable": true,
                "type": "integer"
              },
              "state": {
                "enum": [
                  "healthy",
                  "degraded",
                  "not_configured",
                  "unknown"
                ],
                "type": "string"
              },
              "url": {
                "nullable": true,
                "type": "string"
              }
            },
            "required": [
              "state"
            ],
            "type": "object"
          },
          "docker": {
            "properties": {
              "error": {
                "type": "string"
              },
              "present": {
                "type": "boolean"
              },
              "version": {
                "nullable": true,
                "type": "string"
              }
            },
            "required": [
              "present"
            ],
            "type": "object"
          },
          "postgres": {
            "properties": {
              "error": {
                "type": "string"
              },
              "last_write_at": {
                "format": "date-time",
                "nullable": true,
                "type": "string"
              },
              "row_count_estimate": {
                "nullable": true,
                "type": "integer"
              },
              "schema_version": {
                "nullable": true,
                "type": "integer"
              },
              "state": {
                "enum": [
                  "healthy",
                  "degraded",
                  "unknown"
                ],
                "type": "string"
              }
            },
            "required": [
              "state"
            ],
            "type": "object"
          },
          "webhook_target": {
            "properties": {
              "configured": {
                "type": "boolean"
              },
              "error": {
                "type": "string"
              },
              "last_delivery_at": {
                "format": "date-time",
                "nullable": true,
                "type": "string"
              },
              "last_status": {
                "nullable": true,
                "type": "string"
              }
            },
            "required": [
              "configured"
            ],
            "type": "object"
          },
          "worker": {
            "properties": {
              "error": {
                "type": "string"
              },
              "queue_depth": {
                "nullable": true,
                "type": "integer"
              },
              "state": {
                "enum": [
                  "running",
                  "stopped",
                  "unknown"
                ],
                "type": "string"
              },
              "uptime_seconds": {
                "nullable": true,
                "type": "integer"
              }
            },
            "required": [
              "state"
            ],
            "type": "object"
          }
        },
        "required": [
          "postgres",
          "clickhouse",
          "worker",
          "webhook_target",
          "api_keys",
          "docker"
        ],
        "type": "object"
      },
      "VisibilityTrendResponse": {
        "properties": {
          "points": {
            "items": {
              "type": "object"
            },
            "type": "array"
          }
        },
        "type": "object"
      }
    },
    "securitySchemes": {
      "ApiKeyAuth": {
        "in": "header",
        "name": "X-OpenGEO-API-Key",
        "type": "apiKey"
      }
    }
  },
  "info": {
    "description": "Phase 2 v1 surface — read endpoints, prompt run submission, and the SSE event stream. Auth: X-OpenGEO-API-Key header carrying an `ogeo_<32 chars>` key. Story 0.11 (Phase 3 substrate) adds the optional X-OpenGEO-Project header — Phase 2 accepts it for forward compatibility; Phase 4 will require it. Story 15.1 adds three `/v1/setup/*` endpoints (deployment UX substrate).",
    "title": "OpenGEO Public REST API",
    "version": "0.3.1"
  },
  "openapi": "3.0.3",
  "paths": {
    "/v1/citations/summary": {
      "get": {
        "operationId": "citationSummary",
        "parameters": [
          {
            "$ref": "#/components/parameters/ProjectHeader"
          },
          {
            "in": "query",
            "name": "limit",
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CitationSummaryResponse"
                }
              }
            },
            "description": "OK"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          }
        }
      }
    },
    "/v1/comparisons": {
      "get": {
        "operationId": "comparisons",
        "parameters": [
          {
            "$ref": "#/components/parameters/ProjectHeader"
          },
          {
            "in": "query",
            "name": "brands",
            "required": true,
            "schema": {
              "description": "Comma-separated; 2..=6 entries. First entry is the subject brand; remainder are competitors in caller-declared order.",
              "type": "string"
            }
          },
          {
            "in": "query",
            "name": "prompts",
            "schema": {
              "description": "Comma-separated prompt names; default = all prompts for the project.",
              "type": "string"
            }
          },
          {
            "in": "query",
            "name": "providers",
            "schema": {
              "description": "Comma-separated provider names; default = all providers.",
              "type": "string"
            }
          },
          {
            "in": "query",
            "name": "window",
            "schema": {
              "default": "7d",
              "enum": [
                "1d",
                "7d",
                "30d"
              ],
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ComparisonsResponse"
                }
              }
            },
            "description": "OK"
          },
          "400": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            },
            "description": "Validation error (e.g. `brands` outside 2..=6, or unknown `window`)."
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          }
        },
        "summary": "Phase 3 Story 0.8 — deterministic brand-vs-competitors comparison matrix (substrate for MCP `compare_brands`)."
      }
    },
    "/v1/healthz": {
      "get": {
        "operationId": "healthz",
        "parameters": [
          {
            "$ref": "#/components/parameters/ProjectHeader"
          }
        ],
        "responses": {
          "200": {
            "content": {
              "text/plain": {
                "schema": {
                  "example": "ok",
                  "type": "string"
                }
              }
            },
            "description": "OK"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          }
        },
        "summary": "Health probe"
      }
    },
    "/v1/projects/{project_id}/events": {
      "get": {
        "operationId": "subscribeEvents",
        "parameters": [
          {
            "$ref": "#/components/parameters/ProjectHeader"
          },
          {
            "in": "path",
            "name": "project_id",
            "required": true,
            "schema": {
              "format": "uuid",
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "content": {
              "text/event-stream": {}
            },
            "description": "text/event-stream subscription"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          },
          "403": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            },
            "description": "Cross-project subscription attempt; key authorized for a different project_id."
          }
        },
        "summary": "Server-Sent Events stream of ARCH-17 lifecycle events for one project."
      }
    },
    "/v1/prompt-runs": {
      "post": {
        "operationId": "createPromptRun",
        "parameters": [
          {
            "$ref": "#/components/parameters/ProjectHeader"
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreatePromptRunRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "202": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CreatePromptRunResponse"
                }
              }
            },
            "description": "Accepted"
          },
          "400": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            },
            "description": "Validation error"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          }
        },
        "summary": "Dispatch a one-shot prompt run for an already-declared Prompt and Provider."
      }
    },
    "/v1/runs": {
      "get": {
        "operationId": "listRuns",
        "parameters": [
          {
            "$ref": "#/components/parameters/ProjectHeader"
          },
          {
            "in": "query",
            "name": "limit",
            "schema": {
              "maximum": 500,
              "minimum": 1,
              "type": "integer"
            }
          },
          {
            "in": "query",
            "name": "offset",
            "schema": {
              "minimum": 0,
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/RunListResponse"
                }
              }
            },
            "description": "OK"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          }
        },
        "summary": "List recent Prompt Runs"
      }
    },
    "/v1/setup/clickhouse/install": {
      "post": {
        "operationId": "clickhouseInstall",
        "parameters": [
          {
            "$ref": "#/components/parameters/ProjectHeader"
          }
        ],
        "responses": {
          "202": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ClickHouseInstallAccepted"
                }
              }
            },
            "description": "Accepted"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          }
        },
        "summary": "Story 15.1 — kick off (MOCK) ClickHouse local-install state machine. Returns 202 with a ULID and an SSE stream URL. Real Docker calls land in Story 15.3."
      }
    },
    "/v1/setup/clickhouse/install-stream": {
      "get": {
        "operationId": "clickhouseInstallStream",
        "parameters": [
          {
            "$ref": "#/components/parameters/ProjectHeader"
          },
          {
            "in": "query",
            "name": "id",
            "required": true,
            "schema": {
              "description": "Install ULID.",
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "content": {
              "text/event-stream": {
                "schema": {
                  "$ref": "#/components/schemas/ClickHouseInstallEvent"
                }
              }
            },
            "description": "text/event-stream — each frame is a ClickHouseInstallEvent serialised as the SSE `data:` field."
          },
          "400": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            },
            "description": "Malformed `id` (not a ULID)."
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          },
          "404": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            },
            "description": "Unknown install `id` — POST /v1/setup/clickhouse/install first."
          }
        },
        "summary": "Story 15.1 — SSE stream of install progress events keyed by `id` (the ULID returned from POST /v1/setup/clickhouse/install). Closes when state reaches `complete` or `failed`."
      }
    },
    "/v1/setup/status": {
      "get": {
        "operationId": "setupStatus",
        "parameters": [
          {
            "$ref": "#/components/parameters/ProjectHeader"
          }
        ],
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SetupStatus"
                }
              }
            },
            "description": "OK"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          }
        },
        "summary": "Story 15.1 — synchronous status probe across Postgres, ClickHouse, worker, webhook target, API keys, and Docker. Always returns 200; individual sections report `state: \"unknown\"` on probe failure or timeout."
      }
    },
    "/v1/visibility/trend": {
      "get": {
        "operationId": "visibilityTrend",
        "parameters": [
          {
            "$ref": "#/components/parameters/ProjectHeader"
          },
          {
            "in": "query",
            "name": "prompt",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "in": "query",
            "name": "days",
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/VisibilityTrendResponse"
                }
              }
            },
            "description": "OK"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          }
        }
      }
    }
  },
  "security": [
    {
      "ApiKeyAuth": []
    }
  ],
  "servers": [
    {
      "description": "Hosted production",
      "url": "https://api.opengeo.dev"
    },
    {
      "description": "Local Compose stack",
      "url": "http://127.0.0.1:8788"
    }
  ]
}

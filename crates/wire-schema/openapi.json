{
  "components": {
    "responses": {
      "Unauthorized": {
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/Error"
            }
          }
        },
        "description": "Missing, malformed, or revoked X-OpenGEO-API-Key. The body shape is intentionally opaque so an unauthenticated caller cannot distinguish 'wrong key' from 'auth backend down'."
      }
    },
    "schemas": {
      "CitationSummaryResponse": {
        "properties": {
          "domains": {
            "items": {
              "type": "object"
            },
            "type": "array"
          }
        },
        "type": "object"
      },
      "CreatePromptRunRequest": {
        "properties": {
          "prompt_name": {
            "description": "Slug-safe prompt identifier declared in opengeo.yaml.",
            "type": "string"
          },
          "provider": {
            "enum": [
              "openai",
              "anthropic",
              "gemini",
              "perplexity",
              "grok",
              "mistral",
              "openrouter",
              "mock"
            ],
            "type": "string"
          },
          "triggered_by": {
            "nullable": true,
            "type": "string"
          }
        },
        "required": [
          "prompt_name",
          "provider"
        ],
        "type": "object"
      },
      "CreatePromptRunResponse": {
        "properties": {
          "dispatched_at": {
            "format": "date-time",
            "type": "string"
          },
          "project_id": {
            "type": "string"
          },
          "prompt_name": {
            "type": "string"
          },
          "provider": {
            "type": "string"
          },
          "run_id": {
            "type": "string"
          },
          "status": {
            "type": "string"
          }
        },
        "required": [
          "status",
          "run_id",
          "project_id",
          "prompt_name",
          "provider",
          "dispatched_at"
        ],
        "type": "object"
      },
      "Error": {
        "properties": {
          "error": {
            "type": "string"
          },
          "message": {
            "type": "string"
          }
        },
        "required": [
          "error",
          "message"
        ],
        "type": "object"
      },
      "RunListResponse": {
        "properties": {
          "runs": {
            "items": {
              "type": "object"
            },
            "type": "array"
          }
        },
        "type": "object"
      },
      "VisibilityTrendResponse": {
        "properties": {
          "points": {
            "items": {
              "type": "object"
            },
            "type": "array"
          }
        },
        "type": "object"
      }
    },
    "securitySchemes": {
      "ApiKeyAuth": {
        "in": "header",
        "name": "X-OpenGEO-API-Key",
        "type": "apiKey"
      }
    }
  },
  "info": {
    "description": "Phase 2 v1 surface — read endpoints, prompt run submission, and the SSE event stream. Auth: X-OpenGEO-API-Key header carrying an `ogeo_<32 chars>` key.",
    "title": "OpenGEO Public REST API",
    "version": "0.2.0"
  },
  "openapi": "3.0.3",
  "paths": {
    "/v1/citations/summary": {
      "get": {
        "operationId": "citationSummary",
        "parameters": [
          {
            "in": "query",
            "name": "limit",
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CitationSummaryResponse"
                }
              }
            },
            "description": "OK"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          }
        }
      }
    },
    "/v1/healthz": {
      "get": {
        "operationId": "healthz",
        "responses": {
          "200": {
            "content": {
              "text/plain": {
                "schema": {
                  "example": "ok",
                  "type": "string"
                }
              }
            },
            "description": "OK"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          }
        },
        "summary": "Health probe"
      }
    },
    "/v1/projects/{project_id}/events": {
      "get": {
        "operationId": "subscribeEvents",
        "parameters": [
          {
            "in": "path",
            "name": "project_id",
            "required": true,
            "schema": {
              "format": "uuid",
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "content": {
              "text/event-stream": {}
            },
            "description": "text/event-stream subscription"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          },
          "403": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            },
            "description": "Cross-project subscription attempt; key authorized for a different project_id."
          }
        },
        "summary": "Server-Sent Events stream of ARCH-17 lifecycle events for one project."
      }
    },
    "/v1/prompt-runs": {
      "post": {
        "operationId": "createPromptRun",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreatePromptRunRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "202": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CreatePromptRunResponse"
                }
              }
            },
            "description": "Accepted"
          },
          "400": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            },
            "description": "Validation error"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          }
        },
        "summary": "Dispatch a one-shot prompt run for an already-declared Prompt and Provider."
      }
    },
    "/v1/runs": {
      "get": {
        "operationId": "listRuns",
        "parameters": [
          {
            "in": "query",
            "name": "limit",
            "schema": {
              "maximum": 500,
              "minimum": 1,
              "type": "integer"
            }
          },
          {
            "in": "query",
            "name": "offset",
            "schema": {
              "minimum": 0,
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/RunListResponse"
                }
              }
            },
            "description": "OK"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          }
        },
        "summary": "List recent Prompt Runs"
      }
    },
    "/v1/visibility/trend": {
      "get": {
        "operationId": "visibilityTrend",
        "parameters": [
          {
            "in": "query",
            "name": "prompt",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "in": "query",
            "name": "days",
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/VisibilityTrendResponse"
                }
              }
            },
            "description": "OK"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          }
        }
      }
    }
  },
  "security": [
    {
      "ApiKeyAuth": []
    }
  ],
  "servers": [
    {
      "description": "Hosted production",
      "url": "https://api.opengeo.dev"
    },
    {
      "description": "Local Compose stack",
      "url": "http://127.0.0.1:8788"
    }
  ]
}

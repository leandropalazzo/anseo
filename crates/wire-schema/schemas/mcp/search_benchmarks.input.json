{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "SearchBenchmarksInput",
  "type": "object",
  "required": [
    "query"
  ],
  "properties": {
    "provider": {
      "type": [
        "string",
        "null"
      ]
    },
    "query": {
      "description": "Free-text or structured category.",
      "type": "string"
    },
    "time_window": {
      "description": "Optional; default `30d` (server-side).",
      "anyOf": [
        {
          "$ref": "#/definitions/Window"
        },
        {
          "type": "null"
        }
      ]
    }
  },
  "additionalProperties": false,
  "definitions": {
    "Window": {
      "description": "Time window vocabulary for trend/visibility/citation queries. Matches the `/v1/.../?window=` query param vocabulary.",
      "type": "string",
      "enum": [
        "7d",
        "30d",
        "all"
      ]
    }
  }
}

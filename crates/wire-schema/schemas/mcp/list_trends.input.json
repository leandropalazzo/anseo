{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "ListTrendsInput",
  "type": "object",
  "required": [
    "project",
    "window"
  ],
  "properties": {
    "min_significance": {
      "description": "Optional [0,1]; default 0.3 (server-side).",
      "type": [
        "number",
        "null"
      ],
      "format": "float"
    },
    "project": {
      "type": "string"
    },
    "window": {
      "$ref": "#/definitions/Window"
    }
  },
  "additionalProperties": false,
  "definitions": {
    "Window": {
      "description": "Time window vocabulary for trend/visibility/citation queries. Matches the `/v1/.../?window=` query param vocabulary.",
      "type": "string",
      "enum": [
        "7d",
        "30d",
        "all"
      ]
    }
  }
}

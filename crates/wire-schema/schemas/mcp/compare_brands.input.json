{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "CompareBrandsInput",
  "type": "object",
  "required": [
    "project"
  ],
  "properties": {
    "project": {
      "type": "string"
    },
    "prompts": {
      "type": [
        "array",
        "null"
      ],
      "items": {
        "type": "string"
      }
    },
    "window": {
      "anyOf": [
        {
          "$ref": "#/definitions/Window"
        },
        {
          "type": "null"
        }
      ]
    }
  },
  "additionalProperties": false,
  "definitions": {
    "Window": {
      "description": "Time window vocabulary for trend/visibility/citation queries. Matches the `/v1/.../?window=` query param vocabulary.",
      "type": "string",
      "enum": [
        "7d",
        "30d",
        "all"
      ]
    }
  }
}

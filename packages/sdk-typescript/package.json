{
  "name": "@anseo/observe",
  "version": "0.1.0",
  "description": "Thin instrumentation SDK to POST externally-executed LLM runs to the Anseo Run-Ingestion API (POST /v1/ingest/run).",
  "license": "MIT",
  "type": "module",
  "main": "./src/index.ts",
  "module": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    }
  },
  "files": [
    "src/**/*.ts",
    "!src/**/*.test.ts",
    "README.md"
  ],
  "scripts": {
    "typecheck": "tsc --noEmit -p .",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "eslint": "^9.0.0",
    "typescript": "^5",
    "typescript-eslint": "^8.0.0",
    "vitest": "^4.1.7"
  },
  "publishConfig": {
    "access": "public"
  }
}
